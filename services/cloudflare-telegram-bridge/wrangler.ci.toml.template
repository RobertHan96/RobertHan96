name = "telegram-memory-bridge"
main = "worker.mjs"
compatibility_date = "2026-03-26"
keep_vars = true

[observability.logs]
enabled = true

[[kv_namespaces]]
binding = "TELEGRAM_MEMORY_KV"
id = "__CLOUDFLARE_TELEGRAM_MEMORY_KV_ID__"

[[r2_buckets]]
binding = "JOB_FIT_REPORTS_BUCKET"
bucket_name = "job-fit-reports"
